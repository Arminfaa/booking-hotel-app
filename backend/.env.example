PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/cove_booking
JWT_SECRET=change-me-to-a-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
SERVICE_FEE_PERCENT=10
TAX_PERCENT=8

# --- Production (Render + Vercel + MongoDB Atlas) ---
# NODE_ENV=production
# MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/cove_booking?retryWrites=true&w=majority
# JWT_SECRET=<long-random-string-min-32-chars>
# CLIENT_URL=https://getcoveapp.vercel.app
# Multiple origins (comma-separated): https://getcoveapp.vercel.app,https://your-app-git-main.vercel.app

# Cloudinary — required in production for image uploads (Render has ephemeral disk)
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# Optional SMTP (otherwise Ethereal test account is used)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
